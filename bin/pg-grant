#!/bin/sh
# proofgate pg-grant: mint a single-use approval token for a require-token rule.
# Refuses to run without a TTY on stdin so an agent can never self-grant.
set -u

if ! test -t 0; then
    echo "pg-grant: refusing to mint a token: stdin is not a TTY." >&2
    echo "pg-grant: a human must run this from a real terminal." >&2
    exit 1
fi

if [ "$#" -ne 1 ] || [ -z "${1:-}" ]; then
    echo "usage: pg-grant <rule-id>" >&2
    exit 2
fi

rid=$1
case $rid in
    *[!A-Za-z0-9._-]* | .*)
        echo "pg-grant: invalid rule id: $rid (allowed: A-Z a-z 0-9 . _ -)" >&2
        exit 2 ;;
esac

# keep this fallback in sync with scripts/gatekeeper/gatekeeper.py
data_dir=${CLAUDE_PLUGIN_DATA:-$HOME/.claude/proofgate}
tok_dir=$data_dir/tokens

mkdir -p "$tok_dir" || exit 1
date +%s > "$tok_dir/$rid.token" || exit 1
echo "pg-grant: granted '$rid' for 15 minutes (single use)."
echo "pg-grant: token: $tok_dir/$rid.token"
